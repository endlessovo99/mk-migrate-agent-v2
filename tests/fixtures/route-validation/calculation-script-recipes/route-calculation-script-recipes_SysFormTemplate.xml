    var groupedTableId = &quot;fd_receipts&quot;;
    function groupedDetail(tableId, controlId, calculation, type) {
      var sum = 0;
      var categoryCount = 0;
      var current_type = &quot;&quot;;
      if (type === &quot;alphaTotal&quot; &amp;&amp; current_type === &quot;alpha&quot;) {
        sum = theFixedNumTwo(sum + 0);
      } else if (type === &quot;betaTotal&quot; &amp;&amp; current_type === &quot;beta&quot;) {
        categoryCount++;
        sum = theFixedNumTwo(sum + 0);
      } else if (type === &quot;gammaTotal&quot; &amp;&amp; current_type === &quot;gamma&quot;) {
        sum = theFixedNumTwo(sum + 0);
