    function calculateLookupRow(value, domElement) {
      var rates = new Map();
      var current = true;
      var sourceDate = getFormFieldValue(&quot;fd_lookup_date&quot;);
      var cutoff = new Date(&quot;2025-01-01 00:00:00&quot;);
      if (sourceDate &amp;&amp; new Date(sourceDate) &lt; cutoff) { current = false; }
      if (current) {
        rates.set(&quot;A&quot;, 1000);
        rates.set(&quot;B&quot;, 800);
      } else {
        rates.set(&quot;A&quot;, 900);
        rates.set(&quot;B&quot;, 700);
      }
      var rowField = domElement;
      var destinationField = GetXFormSameRowFieldById(rowField, &quot;fd_destination&quot;)[0];
      var paidField = GetXFormSameRowFieldById(rowField, &quot;fd_paid&quot;)[0];
      var baseField = GetXFormSameRowFieldById(rowField, &quot;fd_base&quot;)[0];
      var rewardField = GetXFormSameRowFieldById(rowField, &quot;fd_reward&quot;)[0];
      var destination = destinationField.value;
