    function groupedAmount() {
      var alphaTotal = $(&quot;[name=extendDataFormInfo.value(fd_group_alpha)]&quot;);
      var betaTotal = $(&quot;[name=extendDataFormInfo.value(fd_group_beta)]&quot;);
      var gammaTotal = $(&quot;[name=extendDataFormInfo.value(fd_group_gamma)]&quot;);
      var betaTax = $(&quot;[name=extendDataFormInfo.value(fd_group_tax)]&quot;);
      var fullTotal = $(&quot;[name=extendDataFormInfo.value(fd_group_total)]&quot;);
      var taxiTotal = $(&quot;[name=extendDataFormInfo.value(fd_receipt_result)]&quot;);
      var domesticTotal = $(&quot;[name=extendDataFormInfo.value(fd_group_domestic)]&quot;);
      var travelingTax = $(&quot;[name=extendDataFormInfo.value(fd_group_travel_tax)]&quot;);
      var fullSum = 0.00;
      var domesticSum = 0.00;
      fullSum = groupedDetail(groupedTableId, &quot;fd_receipt_value&quot;, alphaTotal, &quot;alphaTotal&quot;);
      domesticSum = groupedDetail(groupedTableId, &quot;fd_receipt_value&quot;, betaTotal, &quot;betaTotal&quot;);
      domesticSum = theFixedNumTwo(domesticSum + groupedDetail(groupedTableId, &quot;fd_receipt_value&quot;, gammaTotal, &quot;gammaTotal&quot;));
      domesticSum = theFixedNumTwo(domesticSum + Number(taxiTotal.val()));
      if (theCityFlag == 0) {
        var cityTaxi = Number(taxiTotal.val());
        fullTotal.val(cityTaxi.toFixed(2));
        domesticTotal.val(cityTaxi.toFixed(2));
      } else {
        fullTotal.val(theFixedNumTwo(fullSum + domesticSum));
        domesticTotal.val(domesticSum.toFixed(2));
