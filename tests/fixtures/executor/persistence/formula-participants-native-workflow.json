    { "id": "L1", "type": "sequenceFlow", "sourceRef": "N1", "targetRef": "N2" },
    { "id": "L2", "type": "sequenceFlow", "sourceRef": "N2", "targetRef": "N3" },
    { "id": "L3", "type": "sequenceFlow", "sourceRef": "N3", "targetRef": "N4" },
    { "id": "L4", "type": "sequenceFlow", "sourceRef": "N4", "targetRef": "N5" },
    { "id": "L5", "type": "sequenceFlow", "sourceRef": "N5", "targetRef": "N6" }
  ]
