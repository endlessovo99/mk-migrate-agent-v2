{
  "calculationOrder": [
    "fd_main_total",
    "fd_lines.fd_line_total",
    "fd_detail_sum",
    "fd_clamped_sum",
    "fd_recompute_output"
  ],
  "mainFormula": {
    "targetField": "fd_main_total",
    "script": "${data.biz.fd_main_left} + ${data.biz.fd_main_right}",
    "display": "$主表左值$ + $主表右值$",
    "fieldIds": ["fd_main_left", "fd_main_right"]
  },
  "detailFormula": {
    "tableId": "fd_lines",
    "targetField": "fd_line_total",
    "script": "${data.biz.fd_quantity} * ${data.biz.fd_unit_price}",
    "display": "$数量$ * $单价$",
    "fieldIds": ["fd_quantity", "fd_unit_price"]
  },
  "aggregate": {
    "targetField": "fd_detail_sum",
    "operation": "SUM",
    "tableId": "fd_lines",
    "sourceField": "fd_line_total"
  },
  "clampAggregate": {
    "targetField": "fd_clamped_sum",
    "operation": "SUM",
    "tableId": "fd_lines",
    "sourceField": "fd_line_total"
  },
  "clampActions": {
    "sourceChange": {
      "event": "onChange",
      "controlId": "fd_line_total",
      "actionId": "source.form.jsp.jsp_clamped_sum.script.1.clamped-aggregate.fd_clamped_sum.source-change",
      "targetCall": "MKXFORM.setValue(\"fd_clamped_sum\", result)"
    },
    "targetChange": {
      "event": "onChange",
      "controlId": "fd_clamped_sum",
      "actionId": "source.form.jsp.jsp_clamped_sum.script.1.clamped-aggregate.fd_clamped_sum.target-change",
      "targetCall": "Math.max(current, 0)"
    },
    "afterDelete": {
      "event": "onAfterDel",
      "actionId": "source.form.jsp.jsp_clamped_sum.script.1.clamped-aggregate.fd_clamped_sum.after-delete",
      "targetCall": "var rawRows = data || []"
    },
    "globalEvents": ["onLoad", "onBeforeSubmit"]
  },
  "runtimeDifferenceFormula": {
    "targetField": "fd_recompute_output",
    "script": "${data.biz.fd_detail_sum} - ${data.biz.fd_recompute_input}",
    "display": "$fd_detail_sum$ - $fd_recompute_input$",
    "fieldIds": ["fd_detail_sum", "fd_recompute_input"]
  },
  "onChange": {
    "controlId": "fd_recompute_input",
    "event": "onChange",
    "actionId": "jsp_recompute.script.1.event.1",
    "runWhen": { "viewStatusIn": ["add", "edit"] },
    "targetCall": "MKXFORM.setValue(\"fd_recompute_output\", Number(value || 0) * 2)"
  },
  "dependencyCycle": {
    "leftField": "fd_main_total",
    "rightField": "fd_clamped_sum",
    "errorCode": "projection.form.calculation_dependency_cycle"
  }
}
